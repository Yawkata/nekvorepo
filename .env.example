TF_VAR_db_password=
TF_VAR_aws_region=
PROJECT_NAME=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=*

DATABASE_URL=

# Per-service database passwords (used by init-db-roles to create/update DB users)
IDENTITY_DB_PASSWORD=
REPO_DB_PASSWORD=
WORKFLOW_DB_PASSWORD=

# Per-service connection URLs (each service connects as its own least-privilege role)
# Format: postgresql+psycopg://<user>:<password>@<host>:5432/<dbname>
# Falls back to DATABASE_URL if not set (safe before init-db-roles has been run)
IDENTITY_DATABASE_URL=
REPO_DATABASE_URL=
WORKFLOW_DATABASE_URL=

PASSPORT_SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

EFS_MOUNT_PATH=

S3_REPO_BUCKET=

SES_FROM_EMAIL=

# SES configuration set name — activates bounce/complaint suppression and
# delivery tracking.  Set to "<project_name>-email-config" after terraform apply.
# Leave blank for local dev (emails sent without a configuration set).
SES_CONFIGURATION_SET_NAME=

# SNS fan-out topic ARN — used by identity-service only.
# Leave blank for local dev (no event publishing without AWS).
SNS_CACHE_INVALIDATION_TOPIC_ARN=

# Per-service SQS queue URLs — each service consumes from its own dedicated queue.
# Populated from terraform outputs after apply.
REPO_CACHE_INVALIDATION_QUEUE_URL=
WORKFLOW_CACHE_INVALIDATION_QUEUE_URL=

# Frontend base URL embedded in invite emails as the accept link.
# Dev default: http://localhost:3000
# Prod: set to your public frontend URL (e.g. https://app.example.com)
INVITE_ACCEPT_BASE_URL=http://localhost:3000