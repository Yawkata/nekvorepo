TF_VAR_db_password=
TF_VAR_aws_region=
PROJECT_NAME=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=*

DATABASE_URL=

# Per-service database passwords (used by init-db-roles to create/update DB users)
IDENTITY_DB_PASSWORD=
REPO_DB_PASSWORD=
WORKFLOW_DB_PASSWORD=

# Per-service connection URLs (each service connects as its own least-privilege role)
# Format: postgresql+psycopg://<user>:<password>@<host>:5432/<dbname>
# Falls back to DATABASE_URL if not set (safe before init-db-roles has been run)
IDENTITY_DATABASE_URL=
REPO_DATABASE_URL=
WORKFLOW_DATABASE_URL=

PASSPORT_SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

EFS_MOUNT_PATH=

S3_REPO_BUCKET=

SES_FROM_EMAIL=

# SQS cache-invalidation queue URL (output of terraform apply).
# Leave blank to disable SQS calls (safe for local dev without AWS).
SQS_CACHE_INVALIDATION_QUEUE_URL=

# Frontend base URL embedded in invite emails as the accept link.
# Dev default: http://localhost:3000
# Prod: set to your public frontend URL (e.g. https://app.example.com)
INVITE_ACCEPT_BASE_URL=http://localhost:3000